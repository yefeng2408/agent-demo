// User 唯一
CREATE CONSTRAINT user_id IF NOT EXISTS
FOR (u:User) REQUIRE u.id IS UNIQUE;

// Entity 唯一（按全局 id）
CREATE CONSTRAINT entity_id IF NOT EXISTS
FOR (e:Entity) REQUIRE e.id IS UNIQUE;

// Predicate 唯一（按 name）
CREATE CONSTRAINT predicate_name IF NOT EXISTS
FOR (p:Predicate) REQUIRE p.name IS UNIQUE;

// Claim 唯一（按 claim id）
CREATE CONSTRAINT claim_id IF NOT EXISTS
FOR (c:Claim) REQUIRE c.id IS UNIQUE;

// Evidence 唯一
CREATE CONSTRAINT evidence_id IF NOT EXISTS
FOR (e:Evidence) REQUIRE e.id IS UNIQUE;

// 常用索引
CREATE INDEX claim_polarity IF NOT EXISTS
FOR (c:Claim) ON (c.polarity);

CREATE INDEX claim_createdAt IF NOT EXISTS
FOR (c:Claim) ON (c.createdAt);